# PDLC AI-Harness secrets & optional overrides.
# Copy this file to `.env` (which is git-ignored) and fill in real values.
# NEVER commit real secrets. .env must be listed in .gitignore.

# --- Secrets (required) ---
# GitHub classic Personal Access Token with the `repo` scope.
# Used by BE-11 to create/push the monorepo and by all git operations.
GITHUB_TOKEN=

# Jira API token: https://id.atlassian.net/manage-profile/security/api-tokens
JIRA_API_TOKEN=

# --- Optional overrides of run-config.json defaults ---
# Uncomment and set to run against your own GitHub repo / Jira instead of the shared defaults.
# GITHUB_OWNER=TimLafleur-w
# GITHUB_REPO=brokeredge
# GITHUB_DEFAULT_BRANCH=main
# JIRA_BASE_URL=https://your-site.atlassian.net
# JIRA_PROJECT_KEY=BE
# JIRA_EMAIL=you@example.com
